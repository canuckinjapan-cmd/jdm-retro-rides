rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "canuck.in.japan@gmail.com" && request.auth.token.email_verified == true) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    function isValidVehicle(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.year is number && data.year > 1900 && data.year < 2100 &&
             data.chassis is string && data.chassis.size() > 0 && data.chassis.size() < 100 &&
             data.img is string && data.img.size() > 0 && data.img.size() < 2000 &&
             data.priceJPY is number && data.priceJPY >= 0 &&
             data.mileage is string &&
             data.mileageKm is number &&
             data.grade is string &&
             data.transmission is string &&
             data.displacementCc is number &&
             data.displacementLabel is string &&
             data.status in ["AVAILABLE", "RESERVED", "SOLD"] &&
             (!('featured' in data) || data.featured is bool);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /vehicles/{vehicleId} {
      allow read: if true; // Public can view inventory
      allow create, update: if isAdmin() && isValidVehicle(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAdmin(); // Only admins can manage roles
    }

    match /_debug/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
