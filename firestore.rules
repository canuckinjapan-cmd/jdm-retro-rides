rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "canuck.in.japan@gmail.com" && request.auth.token.email_verified == true) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    function isValidVehicle(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.stockNumber is string && data.stockNumber.size() > 0 && data.stockNumber.size() < 50 &&
             data.status in ["IN STOCK", "RESERVED", "SOLD"] &&
             data.price is number && data.price >= 0 &&
             data.year is number && data.year > 1900 && data.year < 2100 &&
             data.images is list && data.images.size() > 0 && data.images.size() <= 30 &&
             (!('description' in data) || (data.description is string && data.description.size() < 5000)) &&
             (!('featured' in data) || data.featured is number);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /vehicles/{vehicleId} {
      allow read: if true; // Public can view inventory
      allow create, update: if isAdmin() && isValidVehicle(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAdmin(); // Only admins can manage roles
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
